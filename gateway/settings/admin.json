{
  "service": "admin",
  "endpoints": [
    {
      "endpoint": "/api/v1/admin/users/{user_id}/role",
      "method": "PUT",
      "output_encoding": "no-op",
      "input_headers": [
        "*"
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "jwk_local_path": "/etc/krakend/symmetric.json",
          "disable_jwk_security": true,
          "cookie_key": "access_token",
          "propagate_claims": [
            [
              "sub",
              "X-User-ID"
            ],
            [
              "role",
              "X-Role"
            ],
            [
              "username",
              "X-Username"
            ],
            [
              "iat",
              "X-Token-Iat"
            ]
          ]
        }
      },
      "backend": [
        {
          "url_pattern": "/api/v1/admin/users/{user_id}/role",
          "encoding": "no-op",
          "host": [
            "http://auth-service:8081"
          ]
        }
      ]
    }
  ]
}
