          "encoding": "no-op",
          "host": [
            "http://auth-service:8081"
          ]
        }
      ]
    },
    {
      "endpoint": "/api/v1/auth/profile/{username}",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": [
        "*"
      ],
      "backend": [
        {
          "url_pattern": "/api/v1/auth/profile/{username}",
          "encoding": "no-op",
          "host": [
            "http://auth-service:8081"
          ]
        }
      ]
    },
    {
      "endpoint": "/api/v1/auth/password/change",
      "method": "PUT",
      "output_encoding": "no-op",
      "input_headers": [
        "*"
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "jwk_local_path": "/etc/krakend/symmetric.json",
          "disable_jwk_security": true,
          "cookie_key": "access_token",
          "propagate_claims": [
            [
              "sub",
              "X-User-ID"
            ],
            [
              "role",
              "X-Role"
            ],
            [
              "username",
              "X-Username"
            ],
            [
              "iat",
              "X-Token-Iat"
            ]
          ]
        }
      },
      "backend": [
        {
          "url_pattern": "/api/v1/auth/password/change",
          "encoding": "no-op",
          "host": [
            "http://auth-service:8081"
          ]
        }
      ]
